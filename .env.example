# Copia este archivo a .env y completa tus claves reales.
# NUNCA subas el archivo .env real a un repositorio público.

# Proveedor de LLM a usar: "openai" o "gemini"
LLM_PROVIDER=openai

# --- OpenAI ---
# Requerida SIEMPRE que EMBEDDINGS_PROVIDER=openai (el valor por defecto),
# y también si LLM_PROVIDER=openai.
OPENAI_API_KEY=tu_api_key_de_openai
OPENAI_MODEL=gpt-4o-mini

# --- Google Gemini (alternativa solo para el LLM de chat) ---
GOOGLE_API_KEY=tu_api_key_de_google
GEMINI_MODEL=gemini-1.5-flash

# --- Embeddings del RAG ---
# "openai" (por defecto): liviano y recomendado para desplegar en Render.
# "local": gratis, pero requiere instalar requirements-local-embeddings.txt
#          (agrega PyTorch, ~cientos de MB) y usa mucha más memoria/tiempo.
EMBEDDINGS_PROVIDER=openai
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Modelo de embeddings local (solo se usa si EMBEDDINGS_PROVIDER=local)
EMBEDDINGS_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Parámetros de recuperación (RAG)
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
TOP_K=4

# Rutas
KNOWLEDGE_BASE_DIR=data/base_conocimiento
VECTORSTORE_DIR=vectorstore
